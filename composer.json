{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "druidweb/druid",
  "type": "project",
  "description": "The skeleton application for the Laravel framework.",
  "keywords": [
    "laravel",
    "framework"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "inertiajs/inertia-laravel": "^3.1.0",
    "laravel/chisel": "^0.1.1",
    "laravel/fortify": "^1.35.0",
    "laravel/framework": "^13.0",
    "laravel/sanctum": "^4.3.1",
    "laravel/tinker": "^3.0",
    "laravel/wayfinder": "^0.1.14",
    "mobiledetect/mobiledetectlib": "^4.8.10",
    "nunomaduro/essentials": "^1.2.0",
    "predis/predis": "^3.4.2",
    "zenphp/snowflake": "^3.3.0"
  },
  "require-dev": {
    "driftingly/rector-laravel": "^2.1.12",
    "druidweb/genx": "^1.1.1",
    "fakerphp/faker": "^1.24.1",
    "larastan/larastan": "^3.9.3",
    "laravel/pao": "^1.0",
    "mockery/mockery": "^1.6.12",
    "nunomaduro/collision": "^8.9.1",
    "pestphp/pest": "^4.4.1",
    "pestphp/pest-plugin-laravel": "^4.1.0",
    "pestphp/pest-plugin-type-coverage": "^4.0.3",
    "rector/rector": "^2.3.8",
    "zenphp/fixr": "^1.0.4",
    "zenphp/zorah": "^2.2.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "setup": [
      "composer install",
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@php artisan key:generate",
      "@php artisan migrate --force",
      "bun install",
      "bun run build"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "bunx concurrently -c \"#c4b5fd,#fdba74\" \"php artisan queue:listen --tries=1\" \"bun run dev\" --names=queue,vite --kill-others"
    ],
    "dev:ssr": [
      "bun run build:ssr",
      "Composer\\Config::disableProcessTimeout",
      "bunx concurrently -c \"#c4b5fd,#fdba74\" \"php artisan queue:listen --tries=1\" \"php artisan inertia:start-ssr\" --names=queue,ssr --kill-others"
    ],
    "lint": [
      "./vendor/bin/rector",
      "./vendor/bin/fixr",
      "bun run lint",
      "bun run format"
    ],
    "test:types": "./vendor/bin/pest --type-coverage --parallel --min=100",
    "test:lint": [
      "./vendor/bin/rector --dry-run",
      "./vendor/bin/fixr --test",
      "bun run lint:check",
      "bun run format:check"
    ],
    "test:feat": "./vendor/bin/pest --parallel",
    "test:coverage": "./vendor/bin/pest --parallel --coverage --coverage-clover=coverage.xml --min=100.0; php bin/coverage-clean",
    "test:static": "./vendor/bin/phpstan analyze",
    "test": [
      "@test:types",
      "@test:static",
      "@test:lint",
      "@test:coverage"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
      "@php artisan migrate --graceful --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": [],
      "installer": {
        "post-create-project": [
          "@php artisan install:features --ansi"
        ]
      }
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
